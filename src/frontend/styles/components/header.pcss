html {
    scroll-padding-top: calc(var(--layout-height-header) + 50px);
}

.docs-header {
  display: flex;
  justify-content: flex-start;
  flex-shrink: 0;
  padding: 12px var(--layout-padding-horizontal);
  border-bottom: 1px solid var(--color-line-gray);
  font-size: 18px;
  flex-wrap: wrap;
  box-sizing: border-box;
  position: sticky;
  top: 0;
  background: var(--color-surface-body);
  z-index: 10;

  @media (--not-mobile){
    height: var(--layout-height-header);
  }

  &__menu-link,
  &__logo,
  &__theme-toggle {
    display: inline-block;
    text-decoration: none;
    align-self: center;
    line-height: 24px;
  }

  &__logo {
    padding: 4px 0;
    font-weight: bold;
    color: inherit;
  }

  &__menu-link {
    font-weight: 500;
    transition: background-color .13s;

    @media (--not-mobile) {
      padding: 4px 10px;
      @apply --squircle;
    }

    &:hover {
      background-color: var(--color-link-hover);
    }
  }

  &__theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    cursor: pointer;
    width: 32px;
    height: 32px;
    padding: 0;
    margin-left: 16px;
    flex-shrink: 0;
    line-height: 1;
    transition: background-color .13s;
    @apply --squircle;

    @media (--can-hover) {
      &:hover {
        background-color: var(--color-link-hover);
      }
    }

    @media (--mobile) {
      width: 28px;
      height: 28px;
      margin-left: 12px;
    }
  }

  &__theme-toggle-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;

    svg {
      width: 18px;
      height: 18px;
      display: block;
    }
  }

  &__menu {
    display: flex;
    margin: 0;
    margin-left: auto;
    gap: 10px;
    padding-left: 0;
    font-size: 16px;

    @media (--mobile) {
      margin-top: 6px;
      margin-left: 0;
      flex-basis: 100%;
      font-size: 14px;
    }

    li {
      display: inline-flex;
      align-items: center;
      list-style: none;

      @media (--mobile) {
        margin-left: 0;
        margin-right: 15px;
      }
    }

    li&-add {
      flex-shrink: 0;

      &--desktop {
        @media (--mobile) {
          display: none;
        }
      }

      &--mobile {
        display: none;

        @media (--mobile) {
          display: block;
          position: absolute;
          right: 0;
          top: 13px;
          line-height: 1em;
        }
      }
    }
  }
}

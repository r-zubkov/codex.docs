:root {
  --color-surface-body: #ffffff;
  --color-surface-header: #ffffff;
  --color-surface-elevated: #fcfcff;
  --color-surface-muted: #f8f7fa;
  --color-surface-popover: #ffffff;
  --color-surface-overlay: rgba(0, 0, 0, 0.3);

  --color-text-main: #060C26;
  --color-text-second: #717682;
  --color-text-inverse: #ffffff;
  --color-selection-bg: #c8dcff;
  --color-selection-text: #102d5f;

  --color-line-gray: #E8E8EB;
  --color-line-strong: #d0d0d0;
  --color-button-outline: rgba(184, 189, 206, 0.2);

  --color-link-active: #2071cc;
  --color-link-hover: #F3F6F8;
  --color-page-active: #ff1767;
  --color-input-primary: #F3F6F8;
  --color-input-border: #477CFF;
  --color-focus-ring: rgba(18, 155, 255, 0.33);


  /* Code Block styles */
  --color-code-bg: #252935;
  --color-code-main: #E1EBFE;
  --color-code-keyword: #ff6675;
  --color-code-class: #bf9dff;
  --color-code-variable: #69c6ff;
  --color-code-string: #81bcff;
  --color-code-params: #ffa259;
  --color-code-tag: #74e59d;
  --color-code-number: #ff6262;
  --color-code-comment: #6c7f93;

  /* Button component styles */
  --color-button-primary: #3389FF;
  --color-button-primary-hover: #2E7AE6;
  --color-button-primary-active: #296DCC;

  --color-button-secondary: #717682;
  --color-button-secondary-hover: #5D6068;
  --color-button-secondary-active: #4B4F5B;

  --color-button-warning: #EF5C5C;
  --color-button-warning-hover: #D65151;
  --color-button-warning-active: #BD4848;

  --color-success: #00e08f;
  --color-marker-bg: rgba(245, 235, 111, 0.33);
  --color-warning-bg: #fffad0;
  --color-quote-bg: var(--color-warning-bg);
  --block-quote-border: none;
  --color-checklist-border: #d0d0d0;
  --color-checklist-bg: #ffffff;
  --color-checklist-check: #fcfff4;
  --color-checklist-active: #388ae5;
  --color-shadow-soft: rgba(66, 70, 84, 0.04);
  --color-section-selected-outline: rgba(147, 166, 233, 0.5);

  --color-inline-code-bg: rgba(251, 241, 241, 0.78);
  --color-inline-code-text: #C44545;
  --color-inline-link-border: #000000;
  --color-inline-link-code-border: rgba(84, 151, 255, 0.99);
  --color-inline-link-code-text: #1f6fd8;
  --color-inline-link-code-bg: #daf1fe;
  --color-inline-link-code-bg-hover: #c8edfe;

  --color-sidebar-active-gradient: linear-gradient(270deg, #129bff 0%, #8a53ff 100%);
  --color-sidebar-active-hover: rgba(0, 0, 0, 0.3);

  --asset-icon-search: url("../svg/search.svg");
  --asset-icon-arrow-down: url("../svg/arrow-down.svg");

  --color-bg-light: var(--color-surface-muted);


  /**
   * Site layout sizes
   */
  --layout-padding-horizontal: 22px;
  --layout-padding-vertical: 30px;
  --layout-padding-content-horizontal: 50px;
  --layout-sidebar-width: 280px;
  --layout-width-main-col: 800px;
  --layout-height-header: 56px;

  @media (--mobile) {
    --layout-padding-horizontal: 15px;
    --layout-padding-vertical: 15px;
    --layout-height-header: 88px;
    --layout-padding-content-horizontal: var(--layout-padding-horizontal);
  }

  @media (--wide-desktop) {
    --layout-sidebar-width: 344px;
  }

  --font-mono: Menlo,Monaco,Consolas,Courier New,monospace;

  --button {
    display: inline-block;
    padding: 9px 15px;
    border-radius: 3px;
    color: var(--color-text-second);
    background: var(--color-surface-elevated);
    box-shadow: inset 0 0 0 1px var(--color-button-outline);
    font-size: 14px;
    line-height: 1em;
    text-decoration: none;
    cursor: pointer;
    white-space: nowrap;
    -webkit-appearance: none;
    border: 0;

    svg {
      margin: 0 0.3em 0 -0.05em;
    }
  }


  --button-primary {
    background: var(--color-link-active);
    color: var(--color-text-inverse);
    box-shadow: none;

    &:hover {
      background: color-mod(var(--color-link-active) blackness(+10%));
    }
  }

  --select {
    position: relative;
    padding: 10px 30px 10px 10px;
    width: 100%;
    border: solid 1px transparent;
    border-radius: 8px;
    background-color: var(--color-input-primary);
    box-sizing: border-box;
    appearance: none;
    line-height: 18px;
    color: var(--color-text-main);
    background-image: var(--asset-icon-arrow-down);
    background-repeat: no-repeat;
    background-position: right 15px center;

    &:focus {
      border: solid 1px var(--color-input-border);
      box-shadow: 0 0 0 3px var(--color-focus-ring);
    }

    &:focus-visible {
      outline: none;
    }
  }

  --input {
    padding: 10px;
    width: 100%;
    line-height: 18px;
    border: solid 1px transparent;
    border-radius: 8px;
    background-color: var(--color-input-primary);
    color: var(--color-text-main);
    box-sizing: border-box;

    &:focus {
      border: solid 1px var(--color-input-border);
      box-shadow: 0 0 0 3px var(--color-focus-ring);
    }

    &:focus-visible {
      outline: none;
    }
  }

  --squircle {
    border-radius: 8px;

    @supports(-webkit-mask-box-image: url('')){
      border-radius: 0;
      -webkit-mask-box-image: url("data:image/svg+xml,%3Csvg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 10.3872C0 1.83334 1.83334 0 10.3872 0H13.6128C22.1667 0 24 1.83334 24 10.3872V13.6128C24 22.1667 22.1667 24 13.6128 24H10.3872C1.83334 24 0 22.1667 0 13.6128V10.3872Z' fill='black'/%3E%3C/svg%3E%0A") 48% 41% 37.9% 53.3%;;
    }
  }

  /**
   * The common styles for the Page blocks as well as Editor blocks
   */
  --content-block {
    padding: 10px 0;
  }

  /**
   * Main page H1 title
   */
  --text-content-title {
    font-size: 36px;
    font-weight: 800;
    margin: 0;
  }

  /**
   * Page body font
   */
  --text-content-main {
    font-size: 16px;
    line-height: 150%;
  }

  /**
   * Code on page and in the Editor
   */
  --text-code-block {
    background: var(--color-code-bg);
    color: var(--color-code-main);
    font-family: var(--font-mono);
    line-height: 1.5em;
    font-size: 13px;
    overflow-x: auto;
  }

  /**
   * Common styles for text headings (H2, H3, H4)
   */
  --text-header {
    margin: 20px 0 0;
    line-height: 1.35em;
  }

  /**
   * Styles for the H2 at the Page and Editor
   */
  --text-header-2 {
    font-size: 24px;
    font-weight: 700;
  }

  /**
   * Styles for the H3 at the Page and Editor
   */
  --text-header-3 {
    font-size: 18px;
    font-weight: 700;
  }

  /**
   * Styles for the inline code element at the Page and Editor
   */
  --text-inline-code {
    display: inline-block;
    background: var(--color-inline-code-bg);
    color: var(--color-inline-code-text);
    font-size: 14px;
    line-height: 1.4em;
    letter-spacing: 0;

    padding: 3px 4px 2px;
    margin: -1px 2px 0;
    font-family: var(--font-mono);
    font-size: 0.84em;
    border-bottom: 0;

    &:hover {
      background: var(--color-inline-code-bg);
    }
  }

  /**
   * Styles for regular links inside a text
   */
  --text-inline-link {
    text-decoration: none;
    border-bottom: 1px solid var(--color-inline-link-border);
    padding-bottom: 1px;
    color: inherit;

    &:hover {
      color: var(--color-link-active);
      border-bottom-color: var(--color-link-active);
    }

    /**
     * When a link contain an inline code, highlight it by its own way
     */
    .inline-code {
      margin: 0;
      padding: 2px 5px;
      border-bottom: 1px dashed var(--color-inline-link-code-border);
      color: var(--color-inline-link-code-text);
      background-color: var(--color-inline-link-code-bg);
      border-radius: 3px !important;

      &:hover {
        background-color: var(--color-inline-link-code-bg-hover);
      }
    }
  }

  /**
   * Styles for the List block
   */
  --text-list {
    margin: 0;
    list-style: outside;
    padding-left: 40px;

    &--ordered {
      list-style-type: decimal
    }

    li {
      padding: 0;

      &:not(:last-of-type){
        margin-bottom: 8px;
      }
    }
  }

}

:root[data-theme='dark'] {
  --color-surface-body: #0f141e;
  --color-surface-header: #101826;
  --color-surface-elevated: #131d2b;
  --color-surface-muted: #182233;
  --color-surface-popover: #121b2a;
  --color-surface-overlay: rgba(7, 10, 15, 0.45);

  --color-text-main: #E6EBF5;
  --color-text-second: #A4AFC4;
  --color-selection-bg: #2f5ea8;
  --color-selection-text: #f4f8ff;

  --color-line-gray: #273142;
  --color-line-strong: #374359;
  --color-button-outline: rgba(108, 120, 148, 0.4);

  --color-link-active: #74b1ff;
  --color-link-hover: #1a2536;
  --color-page-active: #ff6e9d;
  --color-input-primary: #151f2e;
  --color-input-border: #74b1ff;
  --color-focus-ring: rgba(116, 177, 255, 0.36);

  --color-code-bg: #111827;
  --color-code-main: #DBE8FF;
  --color-code-keyword: #ff8e9a;
  --color-code-class: #c6afff;
  --color-code-variable: #8fd8ff;
  --color-code-string: #b8d8ff;
  --color-code-params: #ffc080;
  --color-code-tag: #89e7af;
  --color-code-number: #ff8f8f;
  --color-code-comment: #7d8ca0;

  --color-button-primary: #3f95ff;
  --color-button-primary-hover: #5aa5ff;
  --color-button-primary-active: #2c7de0;
  --color-button-secondary: #5f6c84;
  --color-button-secondary-hover: #70809e;
  --color-button-secondary-active: #4f5d74;
  --color-button-warning: #d75c5c;
  --color-button-warning-hover: #e67272;
  --color-button-warning-active: #b74c4c;

  --color-success: #15cc8a;
  --color-marker-bg: rgba(116, 177, 255, 0.28);
  --color-warning-bg: #3b3318;
  --color-quote-bg: #1c2a40;
  --block-quote-border: none;
  --color-checklist-border: #4a5770;
  --color-checklist-bg: #0f1725;
  --color-checklist-check: #e7f0ff;
  --color-checklist-active: #66a8ff;
  --color-shadow-soft: rgba(0, 0, 0, 0.35);
  --color-section-selected-outline: rgba(132, 157, 224, 0.5);

  --color-inline-code-bg: rgba(124, 67, 67, 0.35);
  --color-inline-code-text: #ffb4b4;
  --color-inline-link-border: #d3d9e8;
  --color-inline-link-code-border: rgba(129, 183, 255, 0.95);
  --color-inline-link-code-text: #a6ccff;
  --color-inline-link-code-bg: #173355;
  --color-inline-link-code-bg-hover: #1d3d62;

  --color-sidebar-active-gradient: linear-gradient(270deg, #2f8eff 0%, #7662ff 100%);
  --color-sidebar-active-hover: rgba(255, 255, 255, 0.22);

  --asset-icon-search: url("../svg/search-dark.svg");
  --asset-icon-arrow-down: url("../svg/arrow-down-dark.svg");
}

/**
* Custom media queries
*/
@custom-media --wide-desktop all and (min-width: 1300px);
@custom-media --desktop all and (min-width: 1050px);
@custom-media --tablet all and (min-width: 980px) and (max-width: 1050px);
@custom-media --mobile all and (max-width: 980px);
@custom-media --not-mobile all and (min-width: 981px);
@custom-media --retina all and (-webkit-min-device-pixel-ratio: 1.5);
@custom-media --can-hover all and (hover:hover);
/**
 * Big screens that have additional space around the center column
 */
@custom-media --widest-desktop all and (min-width: 1470px);

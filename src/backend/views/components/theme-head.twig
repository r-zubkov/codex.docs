<meta name="color-scheme" content="light dark">

<script>
  (function () {
    var STORAGE_KEY = 'docs_theme_mode';
    var MODE_SYSTEM = 'system';
    var MODE_DARK = 'dark';
    var MODE_LIGHT = 'light';
    var DARK_THEME_COLOR = '#0f1622';
    var LIGHT_THEME_COLOR = '#ffffff';
    var MANIFEST_THEME_COLOR_PARAM = 'theme_color';
    var MANIFEST_BACKGROUND_COLOR_PARAM = 'background_color';
    var mode;

    try {
      mode = window.localStorage.getItem(STORAGE_KEY);
    } catch (e) {
      mode = null;
    }

    if (mode !== MODE_SYSTEM && mode !== MODE_DARK && mode !== MODE_LIGHT) {
      mode = MODE_SYSTEM;
    }

    var prefersDark = false;

    try {
      prefersDark = !!(window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
    } catch (e) {
      prefersDark = false;
    }

    var theme = mode === MODE_SYSTEM
      ? (prefersDark ? MODE_DARK : MODE_LIGHT)
      : mode;
    var themeColor = theme === MODE_DARK ? DARK_THEME_COLOR : LIGHT_THEME_COLOR;
    var root = document.documentElement;

    root.setAttribute('data-theme-mode', mode);
    root.setAttribute('data-theme', theme);
    root.style.colorScheme = theme;

    var themeColorMeta = document.querySelector('meta[name="theme-color"]');

    if (themeColorMeta) {
      themeColorMeta.setAttribute('content', themeColor);
    }

    var manifestLink = document.querySelector('link[rel="manifest"]');
    var manifestBaseHref = manifestLink
      ? manifestLink.getAttribute('data-manifest-base-href') || manifestLink.getAttribute('href')
      : null;

    if (manifestLink && manifestBaseHref) {
      try {
        var manifestUrl = new URL(manifestBaseHref, window.location.origin);

        manifestUrl.searchParams.set(MANIFEST_THEME_COLOR_PARAM, themeColor);
        manifestUrl.searchParams.set(MANIFEST_BACKGROUND_COLOR_PARAM, themeColor);
        manifestLink.setAttribute('href', manifestUrl.toString());
      } catch (e) {
        // Ignore malformed manifest url
      }
    }
  })();
</script>
